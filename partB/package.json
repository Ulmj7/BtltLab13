{
  "name": "btltlab13-url-shortener",
  "version": "0.1.0",
  "description": "URL Shortener — F.CSM311 Бие даалт 13 (Node.js + Express + PostgreSQL)",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "migrate": "node src/db/migrate.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0"
  },
  "license": "UNLICENSED",
  "private": true,
  "author": "Ulmj (ШУТИС МХТС)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ulmj7/BtltLab13.git"
  }
}
