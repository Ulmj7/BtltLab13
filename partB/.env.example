# .env.example — environment variable-уудын жишээ
#
# Ашиглах заавар:
#   1. Энэ файлыг хуулж `.env` болгож тохируул:
#        cp .env.example .env
#   2. Доорх утгуудыг өөрийн орон нутгийн (local) тохиргоонд тааруулна
#   3. `.env` файлыг ХЭЗЭЭ Ч git-д commit хийхгүй (.gitignore-д бичигдсэн)

# ─────────────────────────────────────────────────────────────
# Сервер
# ─────────────────────────────────────────────────────────────

# HTTP сервер сонсох порт
PORT=3000

# Орчин: development | test | production
NODE_ENV=development

# Үүсгэсэн богино URL-ийн үндэс (host). Production-д бодит домэйнаар сольнө.
# Жишээ: https://btlt.lab/abc123
BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# PostgreSQL холболт
# ─────────────────────────────────────────────────────────────

# Бүрэн connection string (бусад PG* хувьсагчдыг override хийнэ)
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urlshortener

# Тест-д тусдаа DB ашиглана — production өгөгдөл алдагдахаас сэргийлнэ
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urlshortener_test

# pg.Pool тохиргоо (дэлгэрэнгүйг ARCHITECTURE.md §5-аас үзнэ үү)
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────

# Богино кодын урт (тэмдэгт). Дефолт 6 — 62^6 ≈ 56 тэрбум хувилбар
SHORT_CODE_LENGTH=6

# Collision үед хэдэн удаа дахин код үүсгэх оролдох (max retry)
SHORT_CODE_RETRY_MAX=5
